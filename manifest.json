{
  "display_information": {
    "name": "benvu",
    "description": "Benvu is your nonprofit’s AI teammate: finds grants, drafts reports and donor notes, and tracks deadlines — in any language.",
    "long_description": "Benvu is an AI teammate for nonprofit staff, built to help small teams do more with less time.\n\n🌱 Find grants — search real, open U.S. federal funding that fits your mission and budget.\n📝 Draft reports and donor thank-yous — turn a few notes into a ready-to-send draft in seconds.\n⏰ Track deadlines — set a reminder and Benvu nudges your team before it’s due.\n\nMessage Benvu directly, mention it in a channel, or use /grant, /report, and /deadline. It replies in the language you write in."
  },
  "features": {
    "agent_view": {
      "agent_description": "I’m Benvu, your nonprofit’s AI teammate.\n🌱 Find grants — real, open federal funding that fits your mission.\n📝 Draft impact reports and donor thank-yous in seconds.\n⏰ Track deadlines so nothing slips through.\nI reply in any language you write in.",
      "suggested_prompts": []
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "benvu",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/grant",
        "description": "Find grant opportunities",
        "usage_hint": "[what you are looking for]",
        "should_escape": false
      },
      {
        "command": "/report",
        "description": "Draft an impact report",
        "usage_hint": "[what you accomplished]",
        "should_escape": false
      },
      {
        "command": "/deadline",
        "description": "Set a grant deadline reminder",
        "usage_hint": "[grant name] [deadline]",
        "should_escape": false
      },
      {
        "command": "/announce",
        "description": "Create a volunteer announcement",
        "usage_hint": "[event details]",
        "should_escape": false
      },
      {
        "command": "/benvu",
        "description": "Show Benvu help and commands",
        "should_escape": false
      },
      {
        "command": "/benvu-feedback",
        "description": "Admin: view a summary of feedback ratings",
        "should_escape": false
      }
    ],
    "shortcuts": [
      {
        "name": "Send to Benvu",
        "type": "message",
        "callback_id": "send_to_benvu",
        "description": "Summarize, find grants, draft a report, or set a reminder from this message"
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": ["https://ngrok-free.app/slack/oauth_redirect"],
    "scopes": {
      "user": [
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "mpim:history",
        "users:read",
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "canvases:read",
        "canvases:write",
        "users:read.email"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "chat:write.public",
        "commands",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "users.profile:read",
        "assistant:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://ngrok-free.app/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "reaction_added",
        "team_join"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://ngrok-free.app/slack/events"
    },
    "is_mcp_enabled": true,
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
